---
import ReactContactPage from "@/components/contact/ReactContactPage";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { LOCALES, type Lang } from "@/data/locales";
import { buildLanguageAlternates } from "@/lib/seo/meta";
import { getEntry } from "astro:content";

export function getStaticPaths() {
  return LOCALES.map((locale) => ({
    params: {
      lang: locale.code
    }
  }));
}

const lang = Astro.params.lang as Lang;

const entry = await getEntry("pages", `contact-${lang}`);
let content = entry?.data;
let tinaProps:
  | {
      query: string;
      variables: Record<string, unknown>;
      data: Record<string, unknown>;
    }
  | undefined;

if (import.meta.env.DEV) {
  const query = `
    query ContactPage($relativePath: String!) {
      pages(relativePath: $relativePath) {
        id
        _sys {
          filename
          basename
          path
          breadcrumbs
          relativePath
          extension
        }
        lang
        title
        seo {
          title
          description
        }
        contactHero {
          eyebrow
          title
          highlight
          description
          primaryCta {
            label
            href
          }
          secondaryCta {
            label
            href
          }
        }
        contactIntro {
          pretitle
          title
          highlight
          bulletsTitle
          bullets
          footnote
          image
          floatingLabel
        }
        diagnosticSteps {
          title
          description
          footnote
          items {
            number
            title
            description
          }
        }
        contact {
          title
          description
          highlights
          scheduleLabel
          scheduleText
          phone
          email
          form {
            name_label
            name_placeholder
            lastname_label
            lastname_placeholder
            email_label
            email_placeholder
            phone_label
            phone_placeholder
            role_label
            role_placeholder
            message_label
            message_placeholder
            terms_label
            submit_label
          }
        }
        shortcutCta {
          title
          description
          image
          overlayImage
          accentImage
          button {
            label
            href
          }
        }
        locations {
          title
          subtitle
          items {
            city
            address
            image
            summary
            seoLabel
            cta {
              label
              href
            }
          }
        }
        faq {
          title
          items {
            question
            answer
          }
        }
      }
    }
  `;
  const variables = {
    relativePath: `contact-${lang}.md`
  };
  const response = await fetch("http://localhost:4001/graphql", {
    method: "POST",
    headers: {
      "Content-Type": "application/json"
    },
    body: JSON.stringify({ query, variables })
  });
  const result = await response.json();

  if (result?.data?.pages) {
    content = result.data.pages;
    tinaProps = {
      query,
      variables,
      data: result.data
    };
  }
}

if (!content) {
  return Astro.redirect(`/${lang}/404`);
}
---

<BaseLayout
  lang={lang}
  title={content.seo?.title || "Contacto | Efiteca"}
  description={content.seo?.description || "Contacta con un experto hipotecario de Efiteca."}
  path={`/${lang}/contacto/`}
  alternates={buildLanguageAlternates("/contacto/")}
>
  <ReactContactPage client:load content={content} {...tinaProps} />
</BaseLayout>
