---
import ReactSimulatorPage from "@/components/simulator/ReactSimulatorPage";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { LOCALES, type Lang } from "@/data/locales";
import { buildLanguageAlternates } from "@/lib/seo/meta";
import { getEntry } from "astro:content";

export function getStaticPaths() {
  return LOCALES.map((locale) => ({
    params: {
      lang: locale.code
    }
  }));
}

const lang = Astro.params.lang as Lang;

const entry = await getEntry("pages", `simulator-${lang}`);
let content = entry?.data;
let tinaProps:
  | {
      query: string;
      variables: Record<string, unknown>;
      data: Record<string, unknown>;
    }
  | undefined;

if (import.meta.env.DEV) {
  const query = `
    query SimulatorPage($relativePath: String!) {
      pages(relativePath: $relativePath) {
        id
        _sys {
          filename
          basename
          path
          breadcrumbs
          relativePath
          extension
        }
        lang
        title
        seo {
          title
          description
        }
        simulator {
          title
          image
          description
          secondaryDescription
          noteTitle
          noteText
          offerBadge
          calculatorTitle
          resultLabel
          resultValue
          cta {
            label
            href
          }
          sliders {
            label
            value
            progress
          }
        }
        requirementsBanner {
          title
          items
          image
          button {
            label
            href
          }
        }
        calculatorEmbed {
          eyebrow
          title
          description
          src
        }
        testimonials {
          title
          backgroundColor
          description
          items {
            name
            role
            text
            image
            stars
          }
        }
        metrics {
          title
          items {
            title
            value
          }
        }
        contact {
          title
          description
          backgroundColor
          cardBackground
          highlights
          scheduleLabel
          scheduleText
          phone
          email
          form {
            name_label
            name_placeholder
            lastname_label
            lastname_placeholder
            email_label
            email_placeholder
            phone_label
            phone_placeholder
            role_label
            role_placeholder
            message_label
            message_placeholder
            terms_label
            submit_label
          }
        }
        locationsShowcase {
          title
          description
          mapImage
          cta {
            title
            description
            button {
              label
              href
            }
          }
        }
        faq {
          title
          items {
            question
            answer
          }
        }
        locations {
          title
          subtitle
          items {
            city
            address
            image
            summary
            seoLabel
            cta {
              label
              href
            }
          }
        }
      }
    }
  `;
  const variables = {
    relativePath: `simulator-${lang}.md`
  };
  const response = await fetch("http://localhost:4001/graphql", {
    method: "POST",
    headers: {
      "Content-Type": "application/json"
    },
    body: JSON.stringify({ query, variables })
  });
  const result = await response.json();

  if (result?.data?.pages) {
    content = result.data.pages;
    tinaProps = {
      query,
      variables,
      data: result.data
    };
  }
}

if (!content) {
  return Astro.redirect(`/${lang}/404`);
}
---

<BaseLayout
  lang={lang}
  title={content.seo?.title || "Simulador de hipoteca | Efiteca"}
  description={content.seo?.description || "Calcula tu hipoteca con una orientacion clara y conecta con un experto para revisar tu viabilidad real."}
  path={`/${lang}/simulador-hipoteca/`}
  alternates={buildLanguageAlternates("/simulador-hipoteca/")}
>
  <ReactSimulatorPage client:load content={content} {...tinaProps} />
</BaseLayout>
